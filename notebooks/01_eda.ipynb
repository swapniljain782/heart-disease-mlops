import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Load data
columns = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 'thalach', 'exang', 'oldpeak', 'slope', 'ca', 'thal', 'target']
df = pd.read_csv('../data/raw/processed.cleveland.data', names=columns, na_values="?")

# Convert target to binary (0 = no disease, >0 = disease)
df['target'] = df['target'].apply(lambda x: 0 if x == 0 else 1)

sns.set_theme(style="whitegrid")

# 1. Class Balance (Requirement)
plt.figure(figsize=(6, 4))
sns.countplot(data=df, x='target', palette='viridis')
plt.title('Heart Disease Class Distribution (0 = No, 1 = Yes)')
plt.show()

# 2. Histograms for Continuous Variables (Requirement)
fig, axes = plt.subplots(2, 2, figsize=(12, 10))
sns.histplot(df['age'], kde=True, ax=axes[0, 0], color='skyblue').set_title('Age Distribution')
sns.histplot(df['trestbps'], kde=True, ax=axes[0, 1], color='salmon').set_title('Resting Blood Pressure')
sns.histplot(df['chol'], kde=True, ax=axes[1, 0], color='lightgreen').set_title('Cholesterol Level')
sns.histplot(df['thalach'], kde=True, ax=axes[1, 1], color='gold').set_title('Max Heart Rate')
plt.tight_layout()
plt.show()

# 3. Correlation Heatmap (Requirement)
plt.figure(figsize=(12, 8))
corr_matrix = df.corr()
mask = np.triu(np.ones_like(corr_matrix, dtype=bool))
sns.heatmap(corr_matrix, mask=mask, annot=True, fmt=".2f", cmap='coolwarm', vmin=-1, vmax=1)
plt.title('Feature Correlation Heatmap')
plt.show()
